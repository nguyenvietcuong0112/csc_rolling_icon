<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/default_window_bg_color"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Danh sách RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/app_picker_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="70dp"
        android:clipToPadding="false"
        android:scrollbars="vertical" />

    <!-- Thanh tìm kiếm Header -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="18dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="18dp"
        android:layout_gravity="top">

        <EditText
            android:id="@+id/app_picker_search_edit_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#FF434343"
            android:textColorHint="#FFB5B4B4"
            android:background="@drawable/app_picker_search_bg"
            android:padding="12dp"
            android:hint="Tìm kiếm ứng dụng..."
            android:singleLine="true"
            android:drawableLeft="@drawable/app_picker_search"
            android:drawablePadding="8dp" />

        <ImageView
            android:id="@+id/app_picker_search_edit_clear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="right|center_vertical"
            android:layout_marginRight="12dp"
            android:padding="8dp"
            android:src="@drawable/app_picker_search_edit_clear"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true" />
    </FrameLayout>

    <!-- Nút Save nổi ở dưới -->
    <Button
        android:id="@+id/btnSaveSelection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:padding="12dp"
        android:text="LƯU LỰA CHỌN"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#3498db" />

    <!-- Loading Indicator -->
    <ProgressBar
        android:id="@+id/loading_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />
</FrameLayout>
