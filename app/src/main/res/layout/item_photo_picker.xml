<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="120dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#F5D8B3"
        app:strokeColor="#2E1C0C"
        app:strokeWidth="2dp">

        <!-- Trạng thái 1: Hiển thị Ảnh đã chọn -->
        <RelativeLayout
            android:id="@+id/photo_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <ImageView
                android:id="@+id/imgPhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />

            <!-- Bottom bar controls -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:layout_alignParentBottom="true"
                android:background="#B32E1C0C"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="8dp"
                android:paddingRight="8dp">

                <!-- Nút Sửa/Cắt ảnh -->
                <ImageView
                    android:id="@+id/btnEditPhoto"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/photo_icon_picker_edit_button"
                    android:padding="2dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:tint="#FFFFFF" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <!-- Nút Xóa ảnh -->
                <ImageView
                    android:id="@+id/btnDeletePhoto"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/photo_icon_picker_delete_button"
                    android:padding="2dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:tint="#C85C32" />

            </LinearLayout>

        </RelativeLayout>

        <!-- Trạng thái 2: Nút thêm ảnh (+) -->
        <FrameLayout
            android:id="@+id/add_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F5D8B3"
            android:visibility="visible">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/photo_icon_picker_add_bt"
                android:scaleType="centerInside" />

        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
