<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:layout_margin="16dp"
    android:background="@drawable/bg_dialog_vintage"
    android:gravity="center">

    <!-- Delete Photo Dialog Title -->
    <TextView
        android:id="@+id/txtDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/delete_photo_title"
        android:textColor="#2E1C0C"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:fontFamily="@font/app_font" />

    <!-- Delete Photo Dialog Message -->
    <TextView
        android:id="@+id/txtDialogMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/delete_photo_message"
        android:textColor="#2E1C0C"
        android:textSize="15sp"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"
        android:fontFamily="@font/app_font" />

    <!-- Buttons Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Cancel Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDialogCancel"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/btn_cancel"
            android:textColor="#7A3CFA"
            android:gravity="center"
            android:background="@drawable/bg_vintage_button_secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/app_font" />

        <!-- Delete Confirm Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDialogDelete"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/btn_delete"
            android:textColor="@color/white"
            android:background="@drawable/bg_purple_gradient_btn"
            android:gravity="center"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/app_font" />
    </LinearLayout>

    <!-- Native Ad Frame at bottom of dialog -->
    <FrameLayout
        android:id="@+id/fr_ads"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp">

        <include layout="@layout/csc_shimer_top_layout_recycler_native" />
    </FrameLayout>

</LinearLayout>
