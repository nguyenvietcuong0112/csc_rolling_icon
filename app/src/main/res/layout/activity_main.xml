<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cosmic_background"
    android:fitsSystemWindows="false">

    <!-- Header Cosmic Wave Background -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="match_parent"
        android:layout_height="174dp"
        android:background="@drawable/bg_header_curve"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Header Bar Contents -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="44dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txtHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_3d_custom_icons"
            android:textColor="@color/cosmic_white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="@font/app_font"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btnHeaderSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_settings"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/settings_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/headerBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Card 1: Rolling Icon -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardRollingIcon"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_210"
                android:background="@color/transparent"
                android:clickable="true"
                android:focusable="true">

                <!-- Background Image -->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/img_rolling_icon"
                    android:scaleType="fitXY"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Content Layout -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="start"
                    android:layout_marginStart="36dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/guidelineCard1">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/rolling_icon_title"
                        android:textColor="#352585"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/app_font" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/rolling_icon_desc"
                        android:textColor="#6C748E"
                        android:textSize="13sp"
                        android:fontFamily="@font/app_font"
                        android:maxLines="2"
                        android:ellipsize="end" />

                    <!-- Action Button -->
                    <TextView
                        android:id="@+id/btnGetStartedRolling"
                        android:layout_width="@dimen/dp_140"
                        android:layout_height="36dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_btn_rolling_get_started"
                        android:paddingHorizontal="20dp"
                        android:gravity="center"
                        android:text="Get started  ➔"
                        android:textColor="@color/cosmic_white"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/app_font"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guidelineCard1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.55" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Card 2: Spinning Icon -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardSpinningIcon"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_190"
                android:layout_marginBottom="20dp"
                android:background="@color/transparent"
                android:clickable="true"
                android:focusable="true">

                <!-- Background Image -->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/img_spinning_icon"
                    android:scaleType="fitXY"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Content Layout -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="start"
                    android:layout_marginStart="36dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/guidelineCard2">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/spinning_icon_title"
                        android:textColor="#B80E46"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/app_font" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/spinning_icon_desc"
                        android:textColor="#6C748E"
                        android:textSize="13sp"
                        android:fontFamily="@font/app_font"
                        android:maxLines="2"
                        android:ellipsize="end" />

                    <!-- Action Button -->
                    <TextView
                        android:id="@+id/btnGetStartedSpinning"
                        android:layout_width="@dimen/dp_140"
                        android:layout_height="36dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_btn_spinning_get_started"
                        android:paddingHorizontal="20dp"
                        android:gravity="center"
                        android:text="Get started  ➔"
                        android:textColor="@color/cosmic_white"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/app_font"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guidelineCard2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.55" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 2x2 Grid of Small Cards (Styled with standard ConstraintLayout to match cosmic theme) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_16"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <!-- Grid Card 1: Shape Path -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardShapePathIcon"
                        android:layout_width="0dp"
                        android:layout_height="145dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="12dp">

                        <!-- Icon (Circle style) -->
                        <FrameLayout
                            android:id="@+id/iconShapeContainer"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@color/transparent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                          >

                            <ImageView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:src="@drawable/ic_hearting"
                                />
                        </FrameLayout>

                        <!-- Text Content -->
                        <TextView
                            android:id="@+id/txtShapePathTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/shape_path_title"
                            android:textColor="#260193"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/app_font"
                            app:layout_constraintTop_toBottomOf="@id/iconShapeContainer"
                            app:layout_constraintStart_toStartOf="parent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/shape_path_desc"
                            android:textColor="#5C4A8B"
                            android:textSize="11sp"
                            android:fontFamily="@font/app_font"
                            android:maxLines="2"
                            android:ellipsize="end"
                            app:layout_constraintTop_toBottomOf="@id/txtShapePathTitle"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Grid Card 2: Emoji Icon -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardEmojiIcon"
                        android:layout_width="0dp"
                        android:layout_height="145dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:clipToOutline="true"
                        android:background="@drawable/bg_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="12dp">

                        <!-- Icon (Circle style) -->
                        <FrameLayout
                            android:id="@+id/iconEmojiContainer"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@color/transparent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent">

                            <ImageView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:src="@drawable/ic_emoji"
                               />
                        </FrameLayout>

                        <!-- Text Content -->
                        <TextView
                            android:id="@+id/txtEmojiTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/emoji_icon_title"
                            android:textColor="#003AAF"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/app_font"
                            app:layout_constraintTop_toBottomOf="@id/iconEmojiContainer"
                            app:layout_constraintStart_toStartOf="parent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/emoji_icon_desc"
                            android:textColor="#4457A5"
                            android:textSize="11sp"
                            android:fontFamily="@font/app_font"
                            android:maxLines="2"
                            android:ellipsize="end"
                            app:layout_constraintTop_toBottomOf="@id/txtEmojiTitle"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <!-- Grid Card 3: Photo Icon -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardPhotoIcon"
                        android:layout_width="0dp"
                        android:layout_height="145dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:clipToOutline="true"
                        android:background="@drawable/bg_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="12dp">

                        <!-- Icon (Circle style) -->
                        <FrameLayout
                            android:id="@+id/iconPhotoContainer"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@color/transparent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent">

                            <ImageView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:src="@drawable/ic_dashboard_photos"
                                />
                        </FrameLayout>

                        <!-- Text Content -->
                        <TextView
                            android:id="@+id/txtPhotoTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/photo_icon_title"
                            android:textColor="#C5590B"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/app_font"
                            app:layout_constraintTop_toBottomOf="@id/iconPhotoContainer"
                            app:layout_constraintStart_toStartOf="parent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/photo_icon_desc"
                            android:textColor="#58605F"
                            android:textSize="11sp"
                            android:fontFamily="@font/app_font"
                            android:maxLines="2"
                            android:ellipsize="end"
                            app:layout_constraintTop_toBottomOf="@id/txtPhotoTitle"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Grid Card 4: Wallpaper -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardWallpaper"
                        android:layout_width="0dp"
                        android:layout_height="145dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:clipToOutline="true"
                        android:background="@drawable/bg_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="12dp">

                        <!-- Icon (Circle style) -->
                        <FrameLayout
                            android:id="@+id/iconWallpaperContainer"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@color/transparent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            >

                            <ImageView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:src="@drawable/ic_dashboard_wallpaper"
                               />
                        </FrameLayout>

                        <!-- Text Content -->
                        <TextView
                            android:id="@+id/txtWallpaperTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/wallpaper_title"
                            android:textColor="#0D8564"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/app_font"
                            app:layout_constraintTop_toBottomOf="@id/iconWallpaperContainer"
                            app:layout_constraintStart_toStartOf="parent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/wallpaper_desc"
                            android:textColor="#3F6768"
                            android:textSize="11sp"
                            android:fontFamily="@font/app_font"
                            android:maxLines="2"
                            android:ellipsize="end"
                            app:layout_constraintTop_toBottomOf="@id/txtWallpaperTitle"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

