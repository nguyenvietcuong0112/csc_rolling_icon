<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/emoji_item_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#F5D8B3"
    app:strokeColor="#2E1C0C"
    app:strokeWidth="2dp"
    android:clickable="true"
    android:focusable="true"
    app:rippleColor="#102E1C0C">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp">

        <ImageView
            android:id="@+id/emoji_item_icon_view"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_gravity="center"
            android:padding="4dp"
            android:scaleType="centerInside" />

        <ImageView
            android:id="@+id/emoji_item_icon_checked_view"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="top|right"
            android:src="@drawable/checkbox_unselected"
            android:visibility="visible" />
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
