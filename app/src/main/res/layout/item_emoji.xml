<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/emoji_item_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:padding="8dp"
    android:background="@drawable/main_block_bt_bg"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <ImageView
        android:id="@+id/emoji_item_icon_view"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:layout_gravity="center"
        android:padding="4dp"
        android:scaleType="centerInside" />

    <!-- Checkbox hiển thị trạng thái selected / unselected rõ ràng -->
    <ImageView
        android:id="@+id/emoji_item_icon_checked_view"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="top|right"
        android:src="@drawable/checkbox_unselected"
        android:visibility="visible" />

</FrameLayout>
