<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="20dp">

    <!-- Dialog Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/txtDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/app_font"
            android:text="Set Wallpaper AS"
            android:textColor="#1A1A1A"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnCloseDialog"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/ic_close_dialog" />
    </RelativeLayout>

    <!-- Option 1: Home Screen -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardOptionHome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#F7F4FF"
        app:strokeWidth="1.5dp"
        app:strokeColor="#8A52FF"
        android:clickable="true"
        android:focusable="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <FrameLayout
                android:id="@+id/iconContainerHome"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_white_rounded_12"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/imgIconHome"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_option_home" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toRightOf="@id/iconContainerHome"
                android:layout_toLeftOf="@+id/radioHome"
                android:layout_centerVertical="true"
                android:layout_marginHorizontal="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/app_font"
                    android:text="Home Screen"
                    android:textColor="#1A1A1A"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/app_font"
                    android:text="Set as wallpaper for home screen"
                    android:textColor="#757575"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/radioHome"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_check_circle" />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Option 2: Lock Screen -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardOptionLock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#F9F9FC"
        app:strokeWidth="1dp"
        app:strokeColor="#EAEAEA"
        android:clickable="true"
        android:focusable="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <FrameLayout
                android:id="@+id/iconContainerLock"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_white_rounded_12"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/imgIconLock"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_option_lock" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toRightOf="@id/iconContainerLock"
                android:layout_toLeftOf="@+id/radioLock"
                android:layout_centerVertical="true"
                android:layout_marginHorizontal="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/app_font"
                    android:text="Lock Screen"
                    android:textColor="#1A1A1A"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/app_font"
                    android:text="Set as wallpaper for lock screen"
                    android:textColor="#757575"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/radioLock"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_circle_unselected" />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Option 3: Lock & Home Screen -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardOptionBoth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#F9F9FC"
        app:strokeWidth="1dp"
        app:strokeColor="#EAEAEA"
        android:clickable="true"
        android:focusable="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <FrameLayout
                android:id="@+id/iconContainerBoth"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_white_rounded_12"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/imgIconBoth"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_option_both" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toRightOf="@id/iconContainerBoth"
                android:layout_toLeftOf="@+id/radioBoth"
                android:layout_centerVertical="true"
                android:layout_marginHorizontal="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/app_font"
                    android:text="Lock &amp; Home Screen"
                    android:textColor="#1A1A1A"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/app_font"
                    android:text="Set Wallpaper for both screen"
                    android:textColor="#757575"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/radioBoth"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_circle_unselected" />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom Set Wallpaper Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSetWallpaper"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_purple_gradient_btn"
        android:fontFamily="@font/app_font"
        android:stateListAnimator="@null"
        android:text="Set Wallpaper"
        android:textColor="@color/cosmic_white"
        android:textSize="15sp"
        android:textStyle="bold" />

</LinearLayout>
