<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#011B1F">

    <!-- SHIMMER: Hiện khi đang Load -->
    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/shimmer_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:shimmer_auto_start="true">
        <include layout="@layout/csc_shimmer_bottom_native_full" />
    </com.facebook.shimmer.ShimmerFrameLayout>


    <com.google.android.gms.ads.nativead.NativeAdView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/native_ad_view"
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:background="@android:color/white"
            android:minHeight="50dp"
            android:orientation="vertical"
            android:scrollbars="none">

            <FrameLayout
                android:id="@+id/closeContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/ad_badge"
                android:layout_marginEnd="16dp"
                android:visibility="gone"
                >
                <TextView
                    android:id="@+id/tvCountdown"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="@android:color/transparent"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone"/>
                <TextView
                    android:id="@+id/btnNext"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/close_ful_ads"
                    android:visibility="gone"
                    />

            </FrameLayout>

            <com.google.android.gms.ads.nativead.MediaView
                android:id="@+id/media_view"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_gravity="center_horizontal"
                android:scrollbars="none"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/closeContainer"
                app:layout_constraintBottom_toTopOf="@+id/ad_headline" />
            <TextView
                android:id="@+id/ad_badge"
                style="@style/AppTheme.AdAttribution"
                android:layout_marginStart="32dp"
                android:layout_marginBottom="150dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />
            <TextView
                android:id="@+id/ad_headline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="6dp"
                android:ellipsize="end"
                android:singleLine="true"
                android:gravity="center"
                android:textSize="20sp"
                android:text="dsdsa"
                android:textStyle="normal"
                android:paddingVertical="8dp"
                android:textColor="@color/black"
                app:layout_constraintBottom_toTopOf="@id/ad_body"
                app:layout_constraintStart_toEndOf="@id/ad_badge" />
            <TextView
                android:id="@+id/ad_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:gravity="center"
                android:text="dsadsaddasd"
                android:paddingHorizontal="6dp"
                android:paddingVertical="8dp"
                android:textColor="@color/black"
                android:textSize="12dp"
                app:layout_constraintStart_toStartOf="@id/ad_headline"
                app:layout_constraintBottom_toTopOf="@+id/ad_call_to_action"
                />
            <androidx.appcompat.widget.AppCompatButton
                android:background="@drawable/bg_button_ads"
                android:id="@+id/ad_call_to_action"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:textSize="12dp"
                android:textColor="@color/white"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/ad_badge"
                android:layout_marginBottom="@dimen/_30sdp"
                />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.gms.ads.nativead.NativeAdView>

</FrameLayout>
