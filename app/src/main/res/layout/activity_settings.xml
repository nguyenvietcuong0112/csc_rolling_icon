<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_dashboard_gradient"
    android:fitsSystemWindows="true">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        android:background="@android:color/transparent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:tint="#2E1C0C" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/settings_title"
            android:textColor="#2E1C0C"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/app_font" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 1. Launch Settings Group -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LAUNCHER SETTINGS"
                android:textColor="#C85C32"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/app_font" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#F5D8B3"
                app:strokeColor="#2E1C0C"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:id="@+id/btnSetDefaultLauncher"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="16dp"
                    android:background="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/make_it_launcher"
                            android:textColor="#2E1C0C"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/app_font" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Set as default home screen"
                            android:textColor="#4E3629"
                            android:textSize="11sp"
                            android:fontFamily="@font/app_font" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_media_play"
                        android:tint="#2E1C0C" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Physics Customization Settings Group -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHYSICS WALLPAPER SETTINGS"
                android:textColor="#C85C32"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/app_font" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#F5D8B3"
                app:strokeColor="#2E1C0C"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Background Image Picker -->
                    <LinearLayout
                        android:id="@+id/btnSelectBgImage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginBottom="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/select_bg_image"
                                android:textColor="#2E1C0C"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/app_font" />

                            <TextView
                                android:id="@+id/txtBgSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/bg_default"
                                android:textColor="#4E3629"
                                android:textSize="11sp"
                                android:fontFamily="@font/app_font" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_media_play"
                            android:tint="#2E1C0C" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#202E1C0C"
                        android:layout_marginBottom="20dp" />

                    <!-- Icon Size Selector -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Icon Size"
                            android:textColor="#2E1C0C"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/app_font" />

                        <!-- Segment Size Controls -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_button_get_started"
                            android:backgroundTint="#EED4B6"
                            android:layout_marginTop="10dp"
                            android:padding="2dp">

                            <TextView
                                android:id="@+id/btnSizeSmall"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/size_small"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/app_font"
                                android:clickable="true"
                                android:focusable="true" />

                            <TextView
                                android:id="@+id/btnSizeMiddle"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/size_middle"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/app_font"
                                android:clickable="true"
                                android:focusable="true" />

                            <TextView
                                android:id="@+id/btnSizeLarge"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/size_large"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/app_font"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#202E1C0C"
                        android:layout_marginBottom="20dp" />

                    <!-- Enable Wallpaper Touch -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_alignParentLeft="true"
                            android:layout_toLeftOf="@id/switchWallpaperTouch"
                            android:layout_marginRight="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Touch Interaction"
                                android:textColor="#2E1C0C"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/app_font" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Interact with icons on wallpaper touch"
                                android:textColor="#4E3629"
                                android:textSize="11sp"
                                android:fontFamily="@font/app_font" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchWallpaperTouch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            app:thumbTint="#C85C32"
                            app:trackTint="#EED4B6" />
                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. Floating Button Group -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FLOATING BUTTON"
                android:textColor="#C85C32"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/app_font" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#F5D8B3"
                app:strokeColor="#2E1C0C"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_alignParentLeft="true"
                            android:layout_toLeftOf="@id/switchFloatButton"
                            android:layout_marginRight="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/enable_float_button"
                                android:textColor="#2E1C0C"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/app_font" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/float_button_desc"
                                android:textColor="#4E3629"
                                android:textSize="11sp"
                                android:fontFamily="@font/app_font" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchFloatButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            app:thumbTint="#C85C32"
                            app:trackTint="#EED4B6" />
                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4. Support Group -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SUPPORT INFORMATION"
                android:textColor="#C85C32"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/app_font" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#F5D8B3"
                app:strokeColor="#2E1C0C"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Rate Us -->
                    <LinearLayout
                        android:id="@+id/btnRateUs"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/menu_rate_us"
                            android:textColor="#2E1C0C"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/app_font" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#202E1C0C" />

                    <!-- Feedback -->
                    <LinearLayout
                        android:id="@+id/btnFeedback"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/menu_feedback"
                            android:textColor="#2E1C0C"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/app_font" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#202E1C0C" />

                    <!-- About Ads -->
                    <LinearLayout
                        android:id="@+id/btnAboutAds"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/menu_about_ads"
                            android:textColor="#2E1C0C"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/app_font" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#202E1C0C" />

                    <!-- Privacy Policy -->
                    <LinearLayout
                        android:id="@+id/btnPrivacyPolicy"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/menu_privacy_policy"
                            android:textColor="#2E1C0C"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/app_font" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#202E1C0C" />

                    <!-- Service Policy -->
                    <LinearLayout
                        android:id="@+id/btnServicePolicy"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/menu_service_policy"
                            android:textColor="#2E1C0C"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/app_font" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#202E1C0C" />

                    <!-- About Us -->
                    <LinearLayout
                        android:id="@+id/btnAboutUs"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/menu_about_us"
                            android:textColor="#2E1C0C"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/app_font" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
