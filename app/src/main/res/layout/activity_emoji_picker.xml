<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:fitsSystemWindows="true">

    <!-- Header Tiêu đề -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1E1E1E"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="Chọn Emojis để quay"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Tab Bar để chọn nhóm Emojis -->
    <LinearLayout
        android:id="@+id/emoji_group_layout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginRight="16dp"
        android:background="@drawable/main_block_bt_bg">

        <ImageView
            android:id="@+id/emoji_group_emoji"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/emoji_group_emoji"
            android:background="?android:attr/selectableItemBackground"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#33FFFFFF" />

        <ImageView
            android:id="@+id/emoji_group_animal"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/emoji_group_animal"
            android:background="?android:attr/selectableItemBackground"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#33FFFFFF" />

        <ImageView
            android:id="@+id/emoji_group_love"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/emoji_group_love"
            android:background="?android:attr/selectableItemBackground"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#33FFFFFF" />

        <ImageView
            android:id="@+id/emoji_group_joke"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/emoji_group_joke"
            android:background="?android:attr/selectableItemBackground"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Danh sách Emojis dạng lưới (Grid) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/emoji_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- Thanh nút hành động -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#1E1E1E">

        <Button
            android:id="@+id/btnSaveEmojis"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="LƯU LỰA CHỌN EMOJI"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#2ecc71" />
    </LinearLayout>

</LinearLayout>
