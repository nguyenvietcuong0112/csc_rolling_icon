<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_dashboard_gradient"
    android:fitsSystemWindows="true">

    <!-- Top Title Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        android:background="@android:color/transparent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:tint="#2E1C0C" />

        <TextView
            android:id="@+id/txtHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/spinning_style_title"
            android:textColor="#2E1C0C"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/app_font" />
    </RelativeLayout>

    <!-- Main Tabs -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:tabTextColor="#64748B"
        app:tabSelectedTextColor="#2E1C0C"
        app:tabIndicatorColor="#C85C32"
        app:tabIndicatorHeight="3dp"
        app:tabGravity="fill"
        app:tabMode="fixed"
        app:tabRippleColor="#102E1C0C" />

    <!-- Container for Tab Contents -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Tab 1: Apps Content Layout -->
        <LinearLayout
            android:id="@+id/layoutTabApps"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp">

                <EditText
                    android:id="@+id/appSearchEdit"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:textSize="14sp"
                    android:textColor="#2E1C0C"
                    android:textColorHint="#64748B"
                    android:background="@drawable/bg_search_bar"
                    android:paddingLeft="12dp"
                    android:paddingRight="40dp"
                    android:hint="Search apps..."
                    android:singleLine="true"
                    android:drawableLeft="@drawable/app_picker_search"
                    android:drawablePadding="8dp"
                    android:drawableTint="#2E1C0C"
                    android:fontFamily="@font/app_font" />

                <ImageView
                    android:id="@+id/appSearchClear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="right|center_vertical"
                    android:layout_marginRight="12dp"
                    android:padding="8dp"
                    android:src="@drawable/app_picker_search_edit_clear"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true"
                    android:tint="#2E1C0C" />
            </FrameLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/appRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="6dp"
                android:clipToPadding="false"
                android:scrollbars="vertical" />
        </LinearLayout>

        <!-- Tab 2: Emojis Content Layout -->
        <LinearLayout
            android:id="@+id/layoutTabEmojis"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Sub Category Tabs for Emojis -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_button_get_started"
                android:backgroundTint="#F5D8B3"
                android:layout_margin="12dp"
                android:padding="2dp">

                <ImageView
                    android:id="@+id/emojiTabSmileys"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:src="@drawable/ic_emoji_smileys"
                    android:background="@drawable/bg_vintage_button_secondary"
                    android:scaleType="centerInside"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <ImageView
                    android:id="@+id/emojiTabAnimals"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:src="@drawable/ic_emoji_animals"
                    android:background="@android:color/transparent"
                    android:scaleType="centerInside"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:alpha="0.55" />

                <ImageView
                    android:id="@+id/emojiTabLove"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:src="@drawable/ic_emoji_love"
                    android:background="@android:color/transparent"
                    android:scaleType="centerInside"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:alpha="0.55" />

                <ImageView
                    android:id="@+id/emojiTabJokes"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:src="@drawable/ic_emoji_jokes"
                    android:background="@android:color/transparent"
                    android:scaleType="centerInside"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:alpha="0.55" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/emojiRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="6dp"
                android:clipToPadding="false"
                android:scrollbars="vertical" />
        </LinearLayout>

        <!-- Tab 3: Photos Content Layout -->
        <LinearLayout
            android:id="@+id/layoutTabPhotos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentLeft="true"
                    android:text="Photos from your gallery"
                    android:textColor="#4E3629"
                    android:textSize="13sp"
                    android:fontFamily="@font/app_font" />

                <TextView
                    android:id="@+id/txtPhotoCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:text="@string/zero_photos"
                    android:textColor="#C85C32"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/app_font" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/photoRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="6dp"
                android:clipToPadding="false"
                android:scrollbars="vertical" />
        </LinearLayout>

        <!-- Lottie Loading progress view -->
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/progressBar"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:visibility="gone"
            app:lottie_rawRes="@raw/loading_data"
            app:lottie_autoPlay="true"
            app:lottie_loop="true" />
    </FrameLayout>

    <!-- Bottom Next Button Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#F9EED2"
        android:elevation="8dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_continue"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_vintage_button_terracotta"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/app_font" />
    </LinearLayout>

</LinearLayout>
