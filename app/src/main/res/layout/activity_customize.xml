<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cosmic_background"
    android:fitsSystemWindows="false">

    <!-- Cosmic Header Container -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/transparent"
        android:paddingTop="@dimen/dp_24"
        >

        <!-- Top Header Bar -->
        <RelativeLayout
            android:id="@+id/layoutTitleBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_arrow_back"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="CUSTOMIZE SETTINGS"
                android:textColor="@color/cosmic_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/app_font" />
        </RelativeLayout>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/dp_16"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- 1. Section Chọn Mode -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT DISPLAY MODE"
                android:textColor="@color/cosmic_accent"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/app_font" />

            <!-- Card 1: Live Wallpaper -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLiveWallpaper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/cosmic_white"
                app:strokeColor="@color/cosmic_accent"
                app:strokeWidth="2.5dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Live Wallpaper Mode"
                        android:textColor="@color/cosmic_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/app_font" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your selected apps and photos will roll and tumble as a live wallpaper behind your system home screen."
                        android:textColor="@color/cosmic_text_subtitle"
                        android:textSize="12sp"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/app_font" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 2: Home Launcher -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHomeLauncher"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/cosmic_white"
                app:strokeColor="@color/cosmic_border_light"
                app:strokeWidth="1.0dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Home Launcher Mode"
                        android:textColor="@color/cosmic_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/app_font" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fully replace your system home screen with an interactive physics icon desktop and app drawer."
                        android:textColor="@color/cosmic_text_subtitle"
                        android:textSize="12sp"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/app_font" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Section Cấu hình thông số -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIGURATION OPTIONS"
                android:textColor="@color/cosmic_accent"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/app_font" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/cosmic_white"
                app:strokeColor="@color/cosmic_border_light"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Icon Size -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Icon Size"
                            android:textColor="@color/cosmic_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/app_font" />

                        <!-- Segment Size Controls -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_emoji_tab_container"
                            android:layout_marginTop="8dp"
                            android:padding="3dp">

                            <TextView
                                android:id="@+id/btnSizeSmall"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/size_small"
                                android:textColor="@color/cosmic_text_secondary"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/app_font"
                                android:clickable="true"
                                android:focusable="true" />

                            <TextView
                                android:id="@+id/btnSizeMiddle"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/size_middle"
                                android:textColor="@color/cosmic_text_secondary"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/app_font"
                                android:clickable="true"
                                android:focusable="true" />

                            <TextView
                                android:id="@+id/btnSizeLarge"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/size_large"
                                android:textColor="@color/cosmic_text_secondary"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/app_font"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/cosmic_border_light"
                        android:layout_marginVertical="16dp" />

                    <!-- Touch Interaction Switch -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_alignParentLeft="true"
                            android:layout_toLeftOf="@+id/switchWallpaperTouch"
                            android:layout_marginRight="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Touch Interaction"
                                android:textColor="@color/cosmic_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/app_font" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Allow clicking on rolling icons on the wallpaper"
                                android:textColor="@color/cosmic_text_subtitle"
                                android:textSize="11sp"
                                android:fontFamily="@font/app_font" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchWallpaperTouch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            app:thumbTint="@color/cosmic_accent"
                            app:trackTint="@color/cosmic_border_purple_light" />
                    </RelativeLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/cosmic_border_light"
                        android:layout_marginVertical="16dp" />

                    <!-- Enable Float Button Switch -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_alignParentLeft="true"
                            android:layout_toLeftOf="@+id/switchFloatButton"
                            android:layout_marginRight="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Show Floating Button"
                                android:textColor="@color/cosmic_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/app_font" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Display a floating shortcut button to quickly open this app from the home screen"
                                android:textColor="@color/cosmic_text_subtitle"
                                android:textSize="11sp"
                                android:fontFamily="@font/app_font" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchFloatButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            app:thumbTint="@color/cosmic_accent"
                            app:trackTint="@color/cosmic_border_purple_light" />
                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Button Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="@android:color/transparent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPreviewApply"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="PREVIEW &amp; APPLY"
            android:textColor="@color/cosmic_white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_purple_gradient_btn"
            android:stateListAnimator="@null"
            android:fontFamily="@font/app_font" />
    </FrameLayout>

</LinearLayout>


