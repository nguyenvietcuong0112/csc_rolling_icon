<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_dashboard_gradient"
    android:fitsSystemWindows="true">

    <!-- Top Title Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        android:background="@android:color/transparent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:tint="#2E1C0C" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/select_shape_path"
            android:textColor="#2E1C0C"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/app_font" />
    </RelativeLayout>

    <!-- Subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SELECT SHAPE PATH MAP"
        android:textColor="#C85C32"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:letterSpacing="0.05"
        android:layout_marginBottom="16dp"
        android:fontFamily="@font/app_font" />

    <!-- Grid Layout maps -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="3"
            android:padding="12dp">

            <!-- Card 1: Heart -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHeart"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#F5D8B3"
                app:strokeColor="#2E1C0C"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_shape_heart" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Heart"
                        android:textColor="#2E1C0C"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/app_font" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 2: Infinity -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardInfinity"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#F5D8B3"
                app:strokeColor="#2E1C0C"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_shape_infinity" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Infinity"
                        android:textColor="#2E1C0C"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/app_font" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 3: Star -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStar"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#F5D8B3"
                app:strokeColor="#2E1C0C"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_shape_star" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Star"
                        android:textColor="#2E1C0C"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/app_font" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 4: Flower -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFlower"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#F5D8B3"
                app:strokeColor="#2E1C0C"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_shape_flower" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Flower"
                        android:textColor="#2E1C0C"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/app_font" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 5: Clover -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardClover"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#F5D8B3"
                app:strokeColor="#2E1C0C"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_shape_clover" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clover"
                        android:textColor="#2E1C0C"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/app_font" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 6: Butterfly -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardButterfly"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#F5D8B3"
                app:strokeColor="#2E1C0C"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_shape_butterfly" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Butterfly"
                        android:textColor="#2E1C0C"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/app_font" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>
    </ScrollView>

    <!-- Bottom Next Button Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#F9EED2"
        android:elevation="8dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_continue"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_vintage_button_terracotta"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/app_font" />
    </LinearLayout>

</LinearLayout>
