<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- 1. Background image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/game_window_bg"
        android:scaleType="centerCrop" />

    <!-- 2. libGDX surface view container (Physics engine) -->
    <FrameLayout
        android:id="@+id/gdxContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 3. Top Info Panel (Include background card) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="top"
        android:padding="16dp"
        android:clipChildren="false">

        <!-- Header row (Steps, Level text, Pause button) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false">

            <!-- Remaining Steps Card -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/game_steps_bg"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:id="@+id/txtSteps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lượt"
                    android:textColor="#E0E0E0"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Level Number Title -->
            <TextView
                android:id="@+id/txtLevelTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="MÀN 1"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:shadowColor="#80000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2" />

            <!-- Pause / Exit Button -->
            <ImageView
                android:id="@+id/btnPauseGame"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:src="@drawable/game_menu"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />
        </RelativeLayout>

        <!-- Score progress bar & Stars layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/txtScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFEB3B"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginRight="8dp" />

            <!-- Custom Score Progress Bar -->
            <com.mandg.funny.game.widget.ScoreProgressBar
                android:id="@+id/scoreProgressBar"
                android:layout_width="0dp"
                android:layout_height="14dp"
                android:layout_weight="1" />

            <!-- Custom Stars Indicator -->
            <com.mandg.funny.game.widget.ScoreStarsView
                android:id="@+id/scoreStarsView"
                android:layout_width="60dp"
                android:layout_height="16dp"
                android:layout_marginLeft="8dp" />
        </LinearLayout>

        <!-- Targets List Layout -->
        <com.mandg.funny.game.widget.TargetLayout
            android:id="@+id/targetLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- 4. Matching Block Grid Layer -->
    <com.mandg.funny.game.widget.BlocksLayout
        android:id="@+id/blocksLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="170dp" />

    <!-- 5. Win / Lose Overlay Popups -->
    <FrameLayout
        android:id="@+id/layoutGameOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <!-- Win/Fail card -->
        <LinearLayout
            android:layout_width="290dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/game_panel_bg"
            android:padding="20dp">

            <!-- Title -->
            <TextView
                android:id="@+id/txtOverlayTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="THẮNG CUỘC!"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/game_panel_title_bg"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginTop="-30dp" />

            <!-- Stars display inside win popup -->
            <LinearLayout
                android:id="@+id/layoutWinStars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/imgStar1"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="4dp"
                    android:src="@drawable/game_star_on" />

                <ImageView
                    android:id="@+id/imgStar2"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="4dp"
                    android:src="@drawable/game_star_on" />

                <ImageView
                    android:id="@+id/imgStar3"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="4dp"
                    android:src="@drawable/game_star_on" />
            </LinearLayout>

            <!-- Score / Coins -->
            <TextView
                android:id="@+id/txtOverlayScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Điểm đạt được: 1,200"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="16dp" />

            <LinearLayout
                android:id="@+id/layoutCoinReward"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thưởng: +50"
                    android:textColor="#FFEB3B"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginLeft="4dp"
                    android:src="@drawable/game_coin_icon" />
            </LinearLayout>

            <!-- Actions Buttons -->
            <Button
                android:id="@+id/btnOverlayPrimary"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:text="MÀN TIẾP THEO"
                android:background="@drawable/game_button_yellow"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <Button
                android:id="@+id/btnOverlaySecondary"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:text="THOÁT"
                android:background="@drawable/game_button_green"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginTop="10dp" />

        </LinearLayout>
    </FrameLayout>
</FrameLayout>
