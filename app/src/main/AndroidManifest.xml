<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">


    <uses-feature android:name="android.software.live_wallpaper" android:required="true" />
    <uses-permission android:name="android.permission.BIND_WALLPAPER" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:roundIcon="@android:drawable/sym_def_app_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.NoActionBar">

        <service
            android:name=".wallpaper.RollingWallpaperService"
            android:label="@string/wallpaper_label"
            android:permission="android.permission.BIND_WALLPAPER"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService" />
            </intent-filter>
            <meta-data
                android:name="android.service.wallpaper"
                android:resource="@xml/wallpaper" />
        </service>

        <activity
            android:name=".ui.MainActivity"
            android:label="@string/app_name"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.SettingsActivity"
            android:label="@string/settings_label"
            android:theme="@style/Theme.AppCompat"
            android:exported="false" />

        <activity
            android:name=".ui.AppPickerActivity"
            android:label="Chọn ứng dụng"
            android:theme="@style/Theme.AppCompat"
            android:exported="false" />

        <activity
            android:name=".ui.EmojiPickerActivity"
            android:label="Chọn Emoji"
            android:theme="@style/Theme.AppCompat"
            android:exported="false" />

        <activity
            android:name=".ui.PhotoIconPickerActivity"
            android:label="Photo icon"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:exported="false" />

        <activity
            android:name=".ui.PhotoShowActivity"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:screenOrientation="portrait"
            android:exported="false" />

        <activity
            android:name=".ui.GameLevelMapActivity"
            android:label="Bản đồ màn chơi"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:exported="false" />

        <activity
            android:name=".ui.GamePlayActivity"
            android:label="Chơi game"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:exported="false" />

        <activity
            android:name=".ui.LauncherActivity"
            android:label="@string/app_name"
            android:launchMode="singleInstance"
            android:stateNotNeeded="true"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

    </application>
</manifest>
